# Copy this file to ".env" and adjust the values.

# Port the server listens on
PORT=3000

# Admin password (plain text). On startup the server hashes this with bcrypt.
# For production, prefer ADMIN_PASSWORD_HASH below instead of a plain password.
ADMIN_PASSWORD=admin123

# Pre-computed bcrypt hash of the admin password. If set, it takes precedence
# over ADMIN_PASSWORD. Generate one with:
#   node -e "console.log(require('bcryptjs').hashSync('YOUR_PASSWORD', 10))"
# ADMIN_PASSWORD_HASH=

# Secret used to sign session cookies. Set a long random string in production:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=

# Public base URL of the deployed app. Used to build the QR code target.
# Leave blank for local dev (it is derived from the request automatically).
# Example: https://movie-night.up.railway.app
PUBLIC_URL=

# Where the SQLite file lives. Defaults to ./data/checkin.db
# DB_PATH=./data/checkin.db

# Set to "production" when deploying (enables secure cookies).
# NODE_ENV=production
